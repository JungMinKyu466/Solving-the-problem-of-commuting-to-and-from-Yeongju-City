{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyM3VLLuQM0CKa6ktmb54Uzk"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["Step 1. 좌표 정의 및 산단 중심점"],"metadata":{"id":"f0wjqSsogJNb"}},{"cell_type":"code","source":["import numpy as np\n","\n","complex_coords = [\n","    [36.7798, 128.6197], [36.7751, 128.6167], [36.7808, 128.6076],\n","    [36.7895, 128.6181], [36.7847, 128.6248]\n","]\n","\n","shuttle_stations = [\n","    [36.8104, 128.6283], [36.8178, 128.6276], [36.8231, 128.6280], [36.8233, 128.6356],\n","    [36.8274, 128.6311], [36.8272, 128.6194], [36.8197, 128.6199], [36.8146, 128.6190],\n","    [36.8102, 128.6177], [36.8075, 128.6267], [36.8109, 128.6078], [36.8183, 128.6046],\n","    [36.8308, 128.6078], [36.8674, 128.5253], [36.8693, 128.5323], [36.8731, 128.5242]\n","]\n","\n","depot = np.mean(complex_coords, axis=0).tolist()\n","all_nodes = [depot] + shuttle_stations   # idx 0 = 산단, 1~16 = 정류장\n","print(f\"총 노드 수: {len(all_nodes)}, depot: {depot}\")\n"],"metadata":{"id":"JiUqJ487f0Tf","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777901584695,"user_tz":-540,"elapsed":40,"user":{"displayName":"이진우","userId":"00126575103581706028"}},"outputId":"630fc7f1-d73e-4f59-b098-2aecb0437394"},"execution_count":11,"outputs":[{"output_type":"stream","name":"stdout","text":["총 노드 수: 17, depot: [36.78198, 128.61738]\n"]}]},{"cell_type":"markdown","source":["Step 2. 카카오 API 거리/시간 행렬 생성 (실패 재시도 + 검증 포함)"],"metadata":{"id":"JYv70ZlcgA3H"}},{"cell_type":"code","source":["!pip install ortools requests -q\n","\n","import requests, time\n","import numpy as np\n","import pandas as pd\n","from google.colab import userdata\n","\n","API_KEY = userdata.get('KAKAO_API_KEY')\n","\n","def get_kakao_road_data(origin, dest, retry=2):\n","    url = \"https://apis-navi.kakaomobility.com/v1/directions\"\n","    headers = {\"Authorization\": f\"KakaoAK {API_KEY}\"}\n","    params = {\n","        \"origin\": f\"{origin[1]},{origin[0]}\",\n","        \"destination\": f\"{dest[1]},{dest[0]}\",\n","        \"priority\": \"RECOMMEND\"\n","    }\n","    for _ in range(retry + 1):\n","        try:\n","            res = requests.get(url, params=params, headers=headers, timeout=5)\n","            if res.status_code == 200:\n","                s = res.json()['routes'][0]['summary']\n","                if s.get('result_code', 0) == 0:\n","                    return s['distance'], s['duration']\n","        except Exception:\n","            pass\n","        time.sleep(0.3)\n","    return None, None\n","\n","n = len(all_nodes)\n","dist_matrix = np.zeros((n, n), dtype=int)\n","time_matrix = np.zeros((n, n), dtype=int)\n","fails = []\n","\n","for i in range(n):\n","    for j in range(n):\n","        if i == j:\n","            continue\n","        d, t = get_kakao_road_data(all_nodes[i], all_nodes[j])\n","        if d is None:\n","            fails.append((i, j))\n","            dist_matrix[i][j] = 10**8\n","            time_matrix[i][j] = 10**8\n","        else:\n","            dist_matrix[i][j] = d\n","            time_matrix[i][j] = t\n","        time.sleep(0.1)\n","    print(f\"노드 {i} 완료\")\n","\n","print(f\"실패 셀 수: {len(fails)}\")\n","pd.DataFrame(dist_matrix).to_csv(\"shuttle_dist_matrix.csv\", index=False)\n","pd.DataFrame(time_matrix).to_csv(\"shuttle_time_matrix.csv\", index=False)\n","\n","# 검증: 풍기 클러스터(14,15,16) -> 산단(0) 시간 확인\n","for k in [14, 15, 16]:\n","    print(f\"정류장 {k} -> 산단: {time_matrix[k][0]//60}분 {time_matrix[k][0]%60}초, \"\n","          f\"{dist_matrix[k][0]/1000:.2f} km\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"S1SJlse9f_NA","executionInfo":{"status":"ok","timestamp":1777901854963,"user_tz":-540,"elapsed":267543,"user":{"displayName":"이진우","userId":"00126575103581706028"}},"outputId":"9035ad9c-f688-4fb2-aecd-195137438035"},"execution_count":12,"outputs":[{"output_type":"stream","name":"stdout","text":["노드 0 완료\n","노드 1 완료\n","노드 2 완료\n","노드 3 완료\n","노드 4 완료\n","노드 5 완료\n","노드 6 완료\n","노드 7 완료\n","노드 8 완료\n","노드 9 완료\n","노드 10 완료\n","노드 11 완료\n","노드 12 완료\n","노드 13 완료\n","노드 14 완료\n","노드 15 완료\n","노드 16 완료\n","실패 셀 수: 0\n","정류장 14 -> 산단: 19분 37초, 17.89 km\n","정류장 15 -> 산단: 19분 11초, 18.44 km\n","정류장 16 -> 산단: 21분 17초, 18.53 km\n"]}]},{"cell_type":"markdown","source":["Step 3. Open VRP용 행렬 변환 + Solver"],"metadata":{"id":"u6h-Xju1gYje"}},{"cell_type":"code","source":["from ortools.constraint_solver import routing_enums_pb2, pywrapcp\n","\n","def build_open_matrices(time_mat, dist_mat):\n","    \"\"\"\n","    원본 인덱스: 0=산단, 1~16=정류장\n","    새 인덱스:  0=dummy(start), 1=산단(end), 2~17=정류장\n","    \"\"\"\n","    n_orig = len(time_mat)        # 17\n","    N = n_orig + 1                # 18\n","    T = np.zeros((N, N), dtype=int)\n","    D = np.zeros((N, N), dtype=int)\n","\n","    def new_idx(orig):  # 산단 0 -> 1, 정류장 k(1..16) -> k+1\n","        return 1 if orig == 0 else orig + 1\n","\n","    for i in range(n_orig):\n","        for j in range(n_orig):\n","            T[new_idx(i)][new_idx(j)] = time_mat[i][j]\n","            D[new_idx(i)][new_idx(j)] = dist_mat[i][j]\n","\n","    # dummy(0) -> 모든 노드 = 0 (deadhead 무시)\n","    # 모든 노드 -> dummy(0) = 0 (사용 안 함, end는 산단)\n","    T[0, :] = 0; D[0, :] = 0\n","    T[:, 0] = 0; D[:, 0] = 0\n","    return T, D\n","\n","def solve_vrp(time_mat, dist_mat, demands_orig, num_vehicles,\n","              max_ride_sec=2700, max_dist_m=50000, capacity=45,\n","              time_limit=60, allow_drop=False, drop_penalty=10**7):\n","    \"\"\"\n","    demands_orig: 길이 17 (원본 인덱스 기준, demands[0]=0=산단)\n","    \"\"\"\n","    T, D = build_open_matrices(time_mat, dist_mat)\n","    N = len(T)\n","\n","    # 새 인덱스용 demands: idx0=dummy(0), idx1=산단(0), idx2~17=정류장\n","    demands = [0, 0] + list(demands_orig[1:])\n","\n","    starts = [0] * num_vehicles    # dummy\n","    ends   = [1] * num_vehicles    # 산단\n","    manager = pywrapcp.RoutingIndexManager(N, num_vehicles, starts, ends)\n","    routing = pywrapcp.RoutingModel(manager)\n","\n","    def time_cb(fi, ti):\n","        return int(T[manager.IndexToNode(fi)][manager.IndexToNode(ti)])\n","    t_idx = routing.RegisterTransitCallback(time_cb)\n","    routing.SetArcCostEvaluatorOfAllVehicles(t_idx)\n","\n","    # 승차 시간 제약 (dummy->정류장=0이므로, 첫 픽업~산단까지가 누적됨)\n","    routing.AddDimension(t_idx, 0, max_ride_sec, True, \"Time\")\n","\n","    def dist_cb(fi, ti):\n","        return int(D[manager.IndexToNode(fi)][manager.IndexToNode(ti)])\n","    d_idx = routing.RegisterTransitCallback(dist_cb)\n","    routing.AddDimension(d_idx, 0, max_dist_m, True, \"Distance\")\n","\n","    def demand_cb(fi):\n","        return demands[manager.IndexToNode(fi)]\n","    dem_idx = routing.RegisterUnaryTransitCallback(demand_cb)\n","    routing.AddDimensionWithVehicleCapacity(\n","        dem_idx, 0, [capacity] * num_vehicles, True, \"Capacity\"\n","    )\n","\n","    # 디버깅용: 빠지는 노드 허용\n","    if allow_drop:\n","        for node in range(2, N):  # 정류장만\n","            routing.AddDisjunction([manager.NodeToIndex(node)], drop_penalty)\n","\n","    sp = pywrapcp.DefaultRoutingSearchParameters()\n","    sp.first_solution_strategy = (\n","        routing_enums_pb2.FirstSolutionStrategy.PARALLEL_CHEAPEST_INSERTION\n","    )\n","    sp.local_search_metaheuristic = (\n","        routing_enums_pb2.LocalSearchMetaheuristic.GUIDED_LOCAL_SEARCH\n","    )\n","    sp.time_limit.seconds = time_limit\n","\n","    sol = routing.SolveWithParameters(sp)\n","    return manager, routing, sol\n"],"metadata":{"id":"I7u2OjSmgef-","executionInfo":{"status":"ok","timestamp":1777901906155,"user_tz":-540,"elapsed":68,"user":{"displayName":"이진우","userId":"00126575103581706028"}}},"execution_count":13,"outputs":[]},{"cell_type":"markdown","source":["Step 4. 실행 + 결과 출력\n","\n","  실행 전 확인 요소\n","  1. Secret 설정 활성화: 이전 단계에서 만드신 KAKAO_API_KEY 항목 왼쪽의 액세스 허용 스위치가 켜져 있는지 다시 한번 확인해 주세요.\n","  2. 데이터 저장의 이유: 이 코드는 실행할 때마다 API 쿼터를 소모합니다. 한 번 돌려서 CSV를 만들어두면, 나중에 경로 최적화(Step 3)를 수백 번 수정해서 돌려도 비용이 들지 않습니다.\n","  3. 거리 vs 시간: 셔틀버스는 거리보다 '도착 시간'이 더 중요할 때가 많습니다. 코드가 두 가지 행렬을 모두 생성하도록 짜두었으니, 나중에 solve_vrp에 time_matrix를 넣어 \"최단 시간 경로\"를 구할 수도 있습니다."],"metadata":{"id":"2AYkAdfhol7m"}},{"cell_type":"code","source":["dist_matrix = pd.read_csv(\"shuttle_dist_matrix.csv\").to_numpy()\n","time_matrix = pd.read_csv(\"shuttle_time_matrix.csv\").to_numpy()\n","\n","# 정류장별 인원: 일단 균일 5명 (실제로는 클러스터 가중치 반영 권장)\n","demands_orig = [0] + [5] * 16   # 총 80명\n","\n","def print_solution(manager, routing, solution, num_buses):\n","    total_t = 0\n","    used = 0\n","    for v in range(num_buses):\n","        idx = routing.Start(v)\n","        # dummy -> 첫 정류장 점프\n","        idx = solution.Value(routing.NextVar(idx))\n","        if routing.IsEnd(idx):\n","            continue  # 빈 차량\n","        used += 1\n","        route, ride_t, ride_d, load = [], 0, 0, 0\n","        while not routing.IsEnd(idx):\n","            node = manager.IndexToNode(idx)\n","            orig = 0 if node == 1 else node - 1   # 새->원본 인덱스 역변환\n","            route.append(orig)\n","            load += demands_orig[orig] if orig != 0 else 0\n","            nxt = solution.Value(routing.NextVar(idx))\n","            ride_t += routing.GetArcCostForVehicle(idx, nxt, v)\n","            # 거리도 따로 합산\n","            fi, ti = manager.IndexToNode(idx), manager.IndexToNode(nxt)\n","            # build_open_matrices와 동일 매핑 필요 -> 간단히 원본행렬에서 조회\n","            o_from = 0 if fi == 1 else (fi - 1 if fi >= 2 else None)\n","            o_to   = 0 if ti == 1 else (ti - 1 if ti >= 2 else None)\n","            if o_from is not None and o_to is not None:\n","                ride_d += dist_matrix[o_from][o_to]\n","            idx = nxt\n","        # 마지막 산단 추가\n","        route.append(0)\n","        print(f\"■ 버스 {used}호차: {' → '.join(map(str,route))}\")\n","        print(f\"   승객 {load}명, 승차시간 {ride_t//60}분 {ride_t%60}초, \"\n","              f\"거리 {ride_d/1000:.2f} km\")\n","        total_t += ride_t\n","    print(f\"\\n사용 버스: {used}대, 총 승차시간 합 {total_t//60}분\")\n","\n","def run():\n","    for k in range(3, 8):   # 최소 3대부터\n","        print(f\"\\n=== 버스 {k}대 시도 ===\")\n","        m, r, s = solve_vrp(time_matrix, dist_matrix, demands_orig, k,\n","                            max_ride_sec=2700, max_dist_m=50000,\n","                            capacity=45, time_limit=30)\n","        if s:\n","            print(f\"✅ {k}대로 해 발견\")\n","            print_solution(m, r, s, k)\n","            return\n","    print(\"❌ 실패. allow_drop=True로 다시 돌려 어느 노드가 병목인지 확인하세요.\")\n","\n","run()\n"],"metadata":{"id":"beKQ-yVcoj9i","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777901939111,"user_tz":-540,"elapsed":30051,"user":{"displayName":"이진우","userId":"00126575103581706028"}},"outputId":"e4f636b3-4c4d-4d68-aec1-29ff79b1916c"},"execution_count":14,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== 버스 3대 시도 ===\n","✅ 3대로 해 발견\n","■ 버스 1호차: 10 → 9 → 8 → 7 → 2 → 3 → 5 → 4 → 1 → 0\n","   승객 45명, 승차시간 32분 57초, 거리 14.25 km\n","■ 버스 2호차: 16 → 14 → 15 → 6 → 13 → 12 → 11 → 0\n","   승객 35명, 승차시간 43분 4초, 거리 25.71 km\n","\n","사용 버스: 2대, 총 승차시간 합 76분\n"]}]}]}